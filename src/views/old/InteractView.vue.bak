/* ===== 3D 地图面板 ===== */
.map3d-panel {
  /* 网格列内联，不遮挡聊天框 */
  position: sticky;
  top: calc(64px + 1rem);
  height: calc(100vh - 180px);
  min-height: 500px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 16px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

